# ============================================================
# LangChain 1.0 & LangGraph 1.0 学习项目 - 环境变量配置
# ============================================================
# 
# 使用方法:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入你的 API Key
# 3. 运行示例代码
#
# ============================================================

# 默认对话模型（推荐：阿里云千问）
CHAT_MODEL=openai:qwen-plus
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 阿里云 DashScope API（用于千问）
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Groq API（可选，如需切回 Groq）
# 获取地址: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================================
# 图像处理模块专用（模块19、21）
# ============================================================
# 
# 千问文本模型走 DashScope；图像相关示例仍需要 OpenAI
# 如需运行图像相关示例，请设置:
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# 可选配置
# ============================================================

# LangSmith 监控（可选，用于调试和追踪）
# 获取地址: https://smith.langchain.com/
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=langchain-learning

# Pinecone 向量数据库（可选，用于 RAG 高级示例）
# 获取地址: https://www.pinecone.io/
# PINECONE_API_KEY=your_pinecone_api_key_here
